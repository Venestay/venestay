# .env.example
# Requerido: API Key con "Maps JavaScript API" habilitada en Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY=
VITE_GEMINI_API_KEY=

# Variables para Vercel o entornos sin firebase-applet-config.json
# VITE_FIREBASE_API_KEY=tu_api_key
# VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=tu_proyecto_id
# VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
# VITE_FIREBASE_APP_ID=tu_app_id
# VITE_FIREBASE_FIRESTORE_DATABASE_ID=tu_db_id
# Opcionalmente, puedes pegar todo el JSON stringificado en:
# VITE_FIREBASE_CONFIG_JSON={"apiKey": "...", ...}
