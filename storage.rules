rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // =========================================================================
    // Funciones de utilidad para validaciones comunes
    // =========================================================================

    // Verifica que el usuario haya iniciado sesión
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica que el archivo entrante sea una imagen (mime type image/*) 
    // y que su tamaño sea menor o igual a 5 MB (5 * 1024 * 1024 bytes)
    function isValidImage() {
      return request.resource.size <= 5 * 1024 * 1024
             && request.resource.contentType.matches('image/.*');
    }

    // Verifica si el usuario autenticado tiene rol de administrador en Firestore
    function isAdmin() {
      return isAuthenticated() && 
             firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Verifica si el email del usuario está en la lista blanca de autorizados
    function isAuthorizedEmail() {
      return isAuthenticated() && (
        request.auth.token.email == 'anfitrionvenesta@venestay.com' || 
        request.auth.token.email == 'admin@venestay.com'
      );
    }

    // =========================================================================
    // 1. DIRECTORIO DE PERFILES Y KYC
    // =========================================================================
    // Se aplican a 'users' (requerido) y 'profiles' (usado en la app actual)
    match /users/{userId}/{fileName} {
      // Lectura: Pública (necesaria para mostrar avatares en reseñas o a anfitriones)
      allow read: if true;
      // Escritura (crear/actualizar): El usuario debe estar autenticado, 
      // modificar su propio directorio y el archivo debe ser una imagen válida (< 5MB)
      allow create, update: if isAuthenticated() 
                           && request.auth.uid == userId 
                           && isValidImage();
      // Solo administradores o correos autorizados pueden eliminar imágenes
      allow delete: if isAdmin() || isAuthorizedEmail();
    }

    match /profiles/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isAuthenticated() 
                           && request.auth.uid == userId 
                           && isValidImage();
      allow delete: if isAdmin() || isAuthorizedEmail();
    }

    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isAuthenticated() 
                           && request.auth.uid == userId 
                           && isValidImage();
      allow delete: if isAdmin() || isAuthorizedEmail();
    }

    match /kyc/{userId}/{fileName} {
      // Solo el propietario puede subir su propio documento
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf')
        // Permitir si no existe el documento de usuario, si no está definido kycStatus, o si está en los estados permitidos
        && (
          !firestore.exists(/databases/(default)/documents/users/$(userId))
          || !('kycStatus' in firestore.get(/databases/(default)/documents/users/$(userId)).data)
          || firestore.get(/databases/(default)/documents/users/$(userId)).data.kycStatus in ['NOT_SUBMITTED', 'REJECTED', 'UNVERIFIED']
        );

      // NADIE puede leer directamente — solo Cloud Functions via Admin SDK o URLs firmadas
      allow read: if false;
    }

    // =========================================================================
    // 2. DIRECTORIO DE COMPROBANTES DE PAGO
    // =========================================================================
    // Se aplican a 'receipts', 'payment-proofs' y a 'bookings/{bookingId}/payments'
    match /receipts/{bookingId}/{fileName} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && (
        firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.guestId == request.auth.uid ||
        firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.ownerId == request.auth.uid ||
        isAdmin()
      );
      allow create, update: if isAuthenticated() && isValidImage();
      allow delete: if isAuthenticated() && (
        firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.guestId == request.auth.uid ||
        isAdmin()
      );
    }

    match /payment-proofs/{bookingId}/{fileName} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && (
        firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.guestId == request.auth.uid ||
        firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.ownerId == request.auth.uid ||
        isAdmin()
      );
      allow create, update: if isAuthenticated() && isValidImage();
      allow delete: if isAuthenticated() && (
        firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.guestId == request.auth.uid ||
        isAdmin()
      );
    }

    function isValidReceipt() {
      return request.resource.size <= 800 * 1024
             && request.resource.contentType.matches('image/.*');
    }

    match /bookings/{bookingId}/payments/{fileName} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && (
        firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.guestId == request.auth.uid ||
        firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.ownerId == request.auth.uid ||
        isAdmin()
      );
      allow create, update: if isAuthenticated() && isValidReceipt();
      allow delete: if isAuthenticated() && (
        firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.guestId == request.auth.uid ||
        isAdmin()
      );
    }

    // =========================================================================
    // 3. DIRECTORIO DE PROPIEDADES (Listings)
    // =========================================================================
    match /listings/{listingId}/{fileName} {
      // Lectura: Pública (necesario para la landing page e invitados)
      allow read: if true;
      // Escritura: Solo el dueño de la propiedad o un administrador (o cualquiera si es una propiedad nueva)
      allow create, update: if isAuthenticated() && isValidImage() && (
        !firestore.exists(/databases/(default)/documents/listings/$(listingId)) ||
        firestore.get(/databases/(default)/documents/listings/$(listingId)).data.hostId == request.auth.uid ||
        (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
      allow delete: if isAuthenticated() && (
        !firestore.exists(/databases/(default)/documents/listings/$(listingId)) ||
        firestore.get(/databases/(default)/documents/listings/$(listingId)).data.hostId == request.auth.uid ||
        (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // =========================================================================
    // REGLA POR DEFECTO: DENEGAR CUALQUIER ACCESO NO ESPECIFICADO
    // =========================================================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

